# =============================================================================
# CodePath AI — Root environment template
# Copy to `.env` (`cp .env.example .env`) before running `docker compose up`.
# Put REAL secrets only in `.env` (gitignored) — keep this template blank.
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_USER=codepath
POSTGRES_PASSWORD=codepath
POSTGRES_DB=codepath
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Backend ----
# SQLAlchemy connection URL. Host is the docker-compose service name.
DATABASE_URL=postgresql+psycopg2://codepath:codepath@postgres:5432/codepath
BACKEND_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Firebase (backend / server-side) ----
# Leave blank + AUTH_STUB_ENABLED=true to run without Firebase (dev stub).
FIREBASE_PROJECT_ID=
# Host path to your service-account key; docker compose mounts it into the container.
FIREBASE_CREDENTIALS_HOST_FILE=
# Path inside the container where the key is mounted (leave as-is).
FIREBASE_CREDENTIALS_FILE=/run/secrets/firebase-key.json
# true = dev stub identity (no Firebase). Set false for real verification.
AUTH_STUB_ENABLED=true

# ---- Judge0 (code execution, Sprint 4) ----
# Option A — RapidAPI (easiest, no local containers): subscribe to "Judge0 CE"
# on RapidAPI and paste your key below. When set, this takes priority and the
# backend talks to the hosted endpoint; JUDGE0_URL/AUTH_TOKEN are ignored.
JUDGE0_RAPIDAPI_KEY=
JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com
# Option B — self-hosted (opt-in `docker compose --profile judge0 up`). Used only
# when JUDGE0_RAPIDAPI_KEY is empty.
JUDGE0_URL=http://judge0:2358
JUDGE0_AUTH_TOKEN=

# ---- AI (Gemini, Sprint 6) ----
# API key from Google AI Studio (https://aistudio.google.com). Leave empty to
# disable AI features (endpoints return a friendly 503 "not configured").
GEMINI_API_KEY=
# flash-lite has a much higher free-tier quota; plenty for generation/tutoring.
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TEACHER_MODEL=gemini-2.5-flash-lite
# Per-user free-tier guards.
AI_RATE_LIMIT_PER_MINUTE=8
AI_DAILY_LIMIT=200

# ---- Billing (Stripe, Sprint 8) ----
# Leave BILLING_ENABLED=false to make premium gating a no-op (dev default).
BILLING_ENABLED=false
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
CHECKOUT_SUCCESS_URL=http://localhost:5173/subscription?status=success
CHECKOUT_CANCEL_URL=http://localhost:5173/subscription?status=cancel

# ---- Hardening (Sprint 8) ----
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=120

# ---- AI curriculum generation (Sprint 11) ----
# A course is generated per learner (placement -> curriculum). Lessons are built
# in batches (published as they finish) with a pause between batches to stay under
# the Gemini free-tier per-minute limit. Lower the count / disable self-verify to
# save quota while testing.
CURRICULUM_LESSON_COUNT=6
CURRICULUM_EXERCISES_PER_LESSON=2
CURRICULUM_QUIZ_QUESTIONS=3
CURRICULUM_SELF_VERIFY=false
# Lessons per AI request (a whole batch in one call). 6 / 3 = 2 requests total,
# which conserves the Gemini free-tier daily request quota.
CURRICULUM_BATCH_SIZE=3
CURRICULUM_BATCH_PAUSE_SECONDS=30

# ---- Frontend (Vite — must be prefixed with VITE_) ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
