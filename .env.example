# =============================================================================
# CodePath AI — Root environment template
# Copy to `.env` (`cp .env.example .env`) before running `docker compose up`.
# Values below are safe local defaults; override secrets before any real use.
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_USER=codepath
POSTGRES_PASSWORD=codepath
POSTGRES_DB=codepath
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Backend ----
# SQLAlchemy connection URL. Host is the docker-compose service name.
DATABASE_URL=postgresql+psycopg2://codepath:codepath@postgres:5432/codepath
BACKEND_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Firebase Authentication ----
# Server-side verification. Either point at a mounted service-account JSON file
# or leave empty to run the auth middleware in stub mode (development only).
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_FILE=
# When true, the auth middleware accepts a stub identity instead of verifying
# real Firebase tokens. NEVER enable in production.
AUTH_STUB_ENABLED=true

# ---- Frontend (Vite — must be prefixed with VITE_) ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
