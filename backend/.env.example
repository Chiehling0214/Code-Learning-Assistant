# Backend-only env template (for running the API outside Docker).
# When using docker compose, the root .env supplies these instead.

ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg2://codepath:codepath@localhost:5432/codepath
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Firebase / auth
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_FILE=
AUTH_STUB_ENABLED=true
