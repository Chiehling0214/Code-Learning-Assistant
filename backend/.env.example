# Backend-only env template (for running the API outside Docker).
# When using docker compose, the root .env supplies these instead.

ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg2://codepath:codepath@localhost:5432/codepath
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Firebase / auth
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_FILE=
AUTH_STUB_ENABLED=true

# Judge0 code execution.
# RapidAPI mode (recommended to start): paste your "Judge0 CE" RapidAPI key.
# When set, it takes priority over the self-hosted JUDGE0_URL below.
JUDGE0_RAPIDAPI_KEY=
JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com
# Self-hosted mode (used only when JUDGE0_RAPIDAPI_KEY is empty):
JUDGE0_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=

# AI (Gemini). Leave GEMINI_API_KEY empty to disable AI features.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEACHER_MODEL=gemini-2.5-flash
AI_RATE_LIMIT_PER_MINUTE=8
AI_DAILY_LIMIT=200

# Billing (Stripe). Leave BILLING_ENABLED=false to disable premium gating.
BILLING_ENABLED=false
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
CHECKOUT_SUCCESS_URL=http://localhost:5173/subscription?status=success
CHECKOUT_CANCEL_URL=http://localhost:5173/subscription?status=cancel

# Hardening
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=120
